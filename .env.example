# ==============================================================
# GeoRich AI - Environment Configuration Example
# Copy this file to `.env` and adjust values as needed.
# ==============================================================

# ---- Application metadata ----
APP_NAME=GeoRich AI API
APP_VERSION=0.2.0
CONTACT_NAME=GeoRich AI
CONTACT_EMAIL=maintainer@georich-ai.local

# ---- Server ----
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# ---- CORS ----
# Comma-separated list of allowed origins, or "*" for all (dev only).
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---- External data source: data.gov.my ----
DATA_GOV_MY_BASE_URL=https://api.data.gov.my
WEATHER_FORECAST_PATH=/weather/forecast
WEATHER_WARNING_PATH=/weather/warning
EARTHQUAKE_WARNING_PATH=/weather/warning/earthquake

# ---- Keyless external services ----
OPEN_METEO_BASE_URL=https://api.open-meteo.com
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
EXTERNAL_USER_AGENT=GeoRich-AI/0.2 (open-source portfolio MVP)

# ---- Optional PostGIS runtime ----
DATABASE_URL=postgresql+psycopg://georich:georich@db:5432/georich

HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=2

# ---- Logging ----
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=14 days
